{
  "name": "materialx-playground",
  "displayName": "MaterialX Playground",
  "description": "View .mtlx files in the MaterialX Playground web app: view MaterialX documents in a 3D viewer, or edit node graphs in a graph editor.",
  "version": "0.1.0",
  "publisher": "local",
  "private": true,
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18"
  },
  "main": "vscode_extension/src/extension.js",
  "repository": { "type": "git", "url": "https://github.com/joaovbs96/MaterialXNodeDocs" },
  "scripts": {
    "vendor": "node scripts/vendor.mjs",
    "vendor:offline": "node scripts/vendor.mjs --with-materialx",
    "build": "node scripts/build.mjs",
    "build:vendor": "node scripts/build.mjs vendor",
    "build:nodelib": "node scripts/build.mjs nodelib",
    "build:tutorials": "node scripts/build.mjs tutorials",
    "check": "node scripts/build.mjs --check"
  },
  "devDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@babel/standalone": "7.26.10",
    "three": "0.128.0",
    "three-147": "npm:three@0.147.0",
    "katex": "0.16.11",
    "jszip": "3.10.1",
    "reactflow": "11.11.4",
    "dagre": "0.8.5",
    "@highlightjs/cdn-assets": "11.9.0"
  },
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "materialx",
    "usd",
    "usdmtlx",
    "pixar",
    "openusd",
    "vfx",
    "3d",
    "graphics",
    "node graph",
    "shader",
    "shader graph",
    "material",
    "material graph",
    "materialx playground",
    "materialx viewer",
    "materialx editor"
  ],
  "activationEvents": [
    "onCustomEditor:materialxPlayground.editor",
    "onLanguage:mtlx"
  ],
  "contributes": {
    "languages": [
      {
        "id": "mtlx",
        "extensions": [".mtlx"],
        "aliases": ["MaterialX", "mtlx"],
        "configuration": "./vscode_extension/language/mtlx.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mtlx",
        "scopeName": "text.mtlx",
        "path": "./vscode_extension/language/mtlx.tmLanguage.json"
      }
    ],
    "customEditors": [
      {
        "viewType": "materialxPlayground.editor",
        "displayName": "MaterialX Playground",
        "selector": [
          {
            "filenamePattern": "*.mtlx"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "materialxPlayground.open",
        "title": "MaterialX Playground: Open MaterialX Document",
        "enablement": "resourceExtname == .mtlx"
      },
      {
        "command": "materialxPlayground.openDocs",
        "title": "MaterialX Playground: Open Node Library Documentation"
      },
      {
        "command": "materialxPlayground.saveGraph",
        "title": "MaterialX Playground: Save Node Graph to File"
      },
      {
        "command": "materialxPlayground.undoGraph",
        "title": "MaterialX Playground: Undo Node Graph Edit"
      },
      {
        "command": "materialxPlayground.redoGraph",
        "title": "MaterialX Playground: Redo Node Graph Edit"
      }
    ],
    "keybindings": [
      {
        "command": "materialxPlayground.saveGraph",
        "key": "ctrl+s",
        "mac": "cmd+s",
        "when": "activeCustomEditorId == 'materialxPlayground.editor'"
      },
      {
        "command": "materialxPlayground.undoGraph",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "activeCustomEditorId == 'materialxPlayground.editor'"
      },
      {
        "command": "materialxPlayground.redoGraph",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z",
        "when": "activeCustomEditorId == 'materialxPlayground.editor'"
      },
      {
        "command": "materialxPlayground.redoGraph",
        "key": "ctrl+y",
        "when": "activeCustomEditorId == 'materialxPlayground.editor'"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "materialxPlayground.open",
          "when": "resourceExtname == .mtlx"
        },
        {
          "command": "materialxPlayground.openDocs"
        }
      ],
      "explorer/context": [
        {
          "command": "materialxPlayground.open",
          "when": "resourceExtname == .mtlx",
          "group": "materialxPlayground"
        },
        {
          "command": "materialxPlayground.openDocs",
          "when": "resourceExtname == .mtlx",
          "group": "materialxPlayground"
        }
      ],
      "editor/title/context": [
        {
          "command": "materialxPlayground.open",
          "when": "resourceExtname == .mtlx",
          "group": "materialxPlayground"
        },
        {
          "command": "materialxPlayground.openDocs",
          "when": "resourceExtname == .mtlx",
          "group": "materialxPlayground"
        }
      ]
    },
    "configuration": {
      "title": "MaterialX Playground",
      "properties": {
        "materialx.defaultView": {
          "type": "string",
          "enum": [
            "viewer",
            "graph"
          ],
          "default": "graph",
          "description": "Which MaterialX Playground view (the Material Viewer or the Node Graph Editor) is shown first when a .mtlx file is opened with the MaterialX Playground custom editor. The document is loaded into both views either way; this setting only picks which one is initially visible — use the header nav to switch to the other."
        },
        "materialx.openBehavior": {
          "type": "string",
          "enum": [
            "splitRight",
            "sameGroup"
          ],
          "default": "splitRight",
          "enumDescriptions": [
            "Open the playground beside the text editor for the same file, reusing an existing right-hand editor group on repeat opens instead of splitting again every time.",
            "Open the playground in the active editor group (the previous behavior)."
          ],
          "description": "Where the MaterialX Playground opens when a text editor for the same .mtlx file is visible: \"splitRight\" opens it beside that editor, reusing an existing right-hand group rather than creating a new split each time; \"sameGroup\" opens it in the active editor group, replacing (or reusing) whatever tab is already there — the previous behavior."
        },
        "materialx.autoOpenPlayground": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the MaterialX Playground beside the text editor whenever a .mtlx file is opened. Triggers once per file open — closing the playground won't re-trigger it until the file itself is closed and reopened."
        }
      }
    }
  }
}
